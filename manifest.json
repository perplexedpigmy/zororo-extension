{
  "manifest_version": 3,
  "name": "Ororo TV Downloader",
  "version": "1.9.0",
  "description": "Download shows from ororo.tv — all seasons or a specific season with subtitles.",
  "browser_specific_settings": {
    "gecko": {
      "id": "ororo-downloader@example.com",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "storage",
    "downloads",
    "alarms"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ororo Downloader"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://ororo.tv/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
