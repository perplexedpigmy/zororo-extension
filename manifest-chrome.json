{
  "manifest_version": 3,
  "name": "Zororo",
  "version": "1.2.0",
  "description": "One-click downloader for ororo.tv shows and movies with auto-skip, subtitle selection, star ratings, and queue management.",
  "permissions": [
    "storage",
    "downloads",
    "alarms"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zororo"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://ororo.tv/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "web_accessible_resources": [{
    "resources": ["icons/icon128.png"],
    "matches": ["https://ororo.tv/*"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
