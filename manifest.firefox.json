{
  "manifest_version": 3,
  "name": "Ororo TV Downloader",
  "version": "1.7.0",
  "description": "Download shows from ororo.tv — all seasons or a specific season with subtitles.",
  "browser_specific_settings": {
    "gecko": {
      "id": "ororo-downloader@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "downloads",
    "alarms"
  ],
  "optional_permissions": [
    "https://ororo.tv/*"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ororo Downloader"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://ororo.tv/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
