{
  "manifest_version": 3,
  "name": "Zororo",
  "version": "1.2.0",
  "description": "One-click downloader for ororo.tv shows and movies with auto-skip, subtitle selection, star ratings, and queue management.",
  "homepage_url": "https://github.com/perplexedpigmy/zororo-extension",
  "browser_specific_settings": {
    "gecko": {
      "id": "zororo@xmousse.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "downloads",
    "alarms"
  ],
  "optional_permissions": [
    "https://ororo.tv/*"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zororo"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://ororo.tv/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon128.png"
      ],
      "matches": [
        "https://ororo.tv/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
